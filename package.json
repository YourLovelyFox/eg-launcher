{
  "name": "eg-launcher",
  "version": "1.0.0",
  "description": "EG Launcher — Minecraft mods via Modrinth, with permanent Bee's SMP pack support.",
  "main": "dist-electron/main.js",
  "author": "EG Launcher",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.node.json --noEmit && vite build",
    "preview": "vite preview",
    "start": "electron .",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "dist": "npm run build && electron-builder --win --x64 --config.win.signAndEditExecutable=false",
    "dist:dir": "npm run build && electron-builder --win --dir --x64 --config.win.signAndEditExecutable=false"
  },
  "build": {
    "appId": "com.eg.launcher",
    "productName": "EG Launcher",
    "copyright": "Copyright © EG Launcher",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "forceCodeSigning": false,
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "win": {
      "signAndEditExecutable": false,
      "signDlls": false,
      "verifyUpdateCodeSignature": false,
      "target": [
        {
          "target": "zip",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "EG-Launcher-${version}-win-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "EG-Launcher-${version}-win-x64-portable.exe"
    },
    "asar": true
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
