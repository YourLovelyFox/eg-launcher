{
  "name": "eg-launcher",
  "version": "2.0.8",
  "description": "EG Launcher — Minecraft mods via Modrinth, with permanent Bee's SMP pack support.",
  "main": "dist-electron/main.js",
  "author": "EG Launcher",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/YourLovelyFox/eg-launcher.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "node scripts/run-with-env.mjs EG_ENABLE_ADMIN=0 -- npm run build:app",
    "build:admin": "node scripts/run-with-env.mjs EG_ENABLE_ADMIN=1 -- npm run build:app",
    "build:app": "tsc -p tsconfig.node.json --noEmit && vite build",
    "preview": "vite preview",
    "start": "electron .",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "cert:generate": "powershell -ExecutionPolicy Bypass -File scripts/generate-self-signed-cert.ps1",
    "dist": "npm run build && node scripts/run-with-csc.mjs -- npx electron-builder --win nsis --x64 --publish never && node scripts/build-win-uninstaller.mjs",
    "dist:admin": "npm run build:admin && node scripts/run-with-csc.mjs -- npx electron-builder --win nsis --x64 --publish never && node scripts/build-win-uninstaller.mjs",
    "dist:dir": "npm run build && node scripts/run-with-csc.mjs -- npx electron-builder --win --dir --x64 --publish never",
    "dist:linux": "npm run build && electron-builder --linux AppImage --x64 --publish never",
    "dist:uninstaller": "node scripts/build-win-uninstaller.mjs",
    "dist:unsigned": "npm run build && node scripts/run-with-env.mjs CSC_IDENTITY_AUTO_DISCOVERY=false -- npx electron-builder --win nsis --x64 --config.win.signAndEditExecutable=false --publish never && node scripts/build-win-uninstaller.mjs"
  },
  "build": {
    "appId": "com.eg.launcher",
    "productName": "EG Launcher",
    "copyright": "Copyright © EG Launcher",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "icon": "build/icon.png",
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "news/feed.json"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "forceCodeSigning": false,
    "publish": {
      "provider": "github",
      "owner": "YourLovelyFox",
      "repo": "eg-launcher",
      "releaseType": "release"
    },
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": true,
      "signDlls": false,
      "signingHashAlgorithms": ["sha256"],
      "rfc3161TimeStampServer": "http://timestamp.digicert.com",
      "publisherName": ["EG Launcher"],
      "verifyUpdateCodeSignature": false,
      "requestedExecutionLevel": "asInvoker",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "EG-Launcher-${version}-win-${arch}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EG Launcher",
      "uninstallDisplayName": "EG Launcher",
      "include": "build/installer.nsh",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": false,
      "unicode": true,
      "installerLanguages": [
        "en_US"
      ],
      "displayLanguageSelector": false,
      "packElevateHelper": true,
      "artifactName": "EG-Launcher-${version}-win-x64-setup.${ext}"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Game",
      "artifactName": "EG-Launcher-${version}-linux-${arch}.${ext}",
      "synopsis": "EG Launcher — Minecraft mods via Modrinth",
      "description": "EG Launcher — Minecraft mods via Modrinth, with partner SMP support."
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/electron-updater/**/*",
      "**/node_modules/builder-util-runtime/**/*"
    ]
  },
  "dependencies": {
    "electron-updater": "^6.6.2",
    "mysql2": "^3.23.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
