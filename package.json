{
  "name": "eg-launcher",
  "version": "1.0.3",
  "description": "EG Launcher — Minecraft mods via Modrinth, with permanent Bee's SMP pack support.",
  "main": "dist-electron/main.js",
  "author": "EG Launcher",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/YourLovelyFox/eg-launcher.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.node.json --noEmit && vite build",
    "preview": "vite preview",
    "start": "electron .",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "dist": "npm run build && electron-builder --win nsis --x64 --config.win.signAndEditExecutable=false --publish never",
    "dist:dir": "npm run build && electron-builder --win --dir --x64 --config.win.signAndEditExecutable=false --publish never",
    "dist:linux": "npm run build && electron-builder --linux AppImage --x64 --publish never"
  },
  "build": {
    "appId": "com.eg.launcher",
    "productName": "EG Launcher",
    "copyright": "Copyright © EG Launcher",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "forceCodeSigning": false,
    "publish": {
      "provider": "github",
      "owner": "YourLovelyFox",
      "repo": "eg-launcher",
      "releaseType": "release"
    },
    "win": {
      "signAndEditExecutable": false,
      "signDlls": false,
      "verifyUpdateCodeSignature": false,
      "requestedExecutionLevel": "asInvoker",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "EG-Launcher-${version}-win-${arch}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EG Launcher",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "unicode": true,
      "installerLanguages": [
        "en_US"
      ],
      "displayLanguageSelector": false,
      "packElevateHelper": true,
      "artifactName": "EG-Launcher-${version}-win-x64-setup.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Game",
      "artifactName": "EG-Launcher-${version}-linux-${arch}.${ext}",
      "synopsis": "EG Launcher — Minecraft mods via Modrinth",
      "description": "EG Launcher — Minecraft mods via Modrinth, with partner SMP support."
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/electron-updater/**/*",
      "**/node_modules/builder-util-runtime/**/*"
    ]
  },
  "dependencies": {
    "electron-updater": "^6.6.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
