# EG Launcher CMS API
Options -Indexes
<IfModule mod_authz_core.c>
  Require all granted
</IfModule>

# Block non-endpoint PHP / secrets (require() still works server-side)
<Files "config.php">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</Files>
<Files "config.sample.php">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</Files>
<Files "bootstrap.php">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</Files>
